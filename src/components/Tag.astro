---
export interface Props {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
}

const { tag, tagName, size = "sm" } = Astro.props;

let hash = 0;
for (const ch of tag) hash = (hash * 31 + ch.charCodeAt(0)) & 0xffff;
const hue = hash % 360;
const color = `hsl(${hue}, 40%, 32%)`;
---


<li class="inline-block my-1 mr-1">
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "inline-block text-white no-underline rounded hover:opacity-80 transition-opacity focus-visible:outline-2 focus-visible:outline-dashed",
      size === "sm" ? "text-xs px-2.5 py-0.5" : "text-sm px-3 py-1",
    ]}
    style={`background-color: ${color}`}
  >
    {tagName}
  </a>
</li>
 