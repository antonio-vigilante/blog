---
import { getCollection } from "astro:content";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";
import { getPath } from "@/utils/getPath";
import IconHalfMoon from "@/assets/icons/IconHalfMoon.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import IconX from "@/assets/icons/IconX.svg";
import IconInfo from "@/assets/icons/IconInfo.svg";
import IconHash from "@/assets/icons/IconHash.svg";
import IconUser from "@/assets/icons/IconUser.svg";
import IconBook from "@/assets/icons/IconBook.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconGraph from "@/assets/icons/IconGraph.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconRss from "@/assets/icons/IconRss.svg";
import IconMail from "@/assets/icons/IconMail.svg";
import IconPhoto from "@/assets/icons/IconPhoto.svg";
import IconFolder from "@/assets/icons/IconFolder.svg";
import IconMapPin from "@/assets/icons/IconMapPin.svg";
import IconPushpin from "@/assets/icons/IconPushpin.svg";

const { pathname } = Astro.url;
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;
const isActive = (path: string) =>
  currentPath === path || currentPath.startsWith(path + "/");

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured).slice(0, 5);
---

<aside
  id="sidebar"
  class="bg-white lg:w-64 lg:shrink-0 lg:flex lg:flex-col"
>
  <!-- Barra superiore mobile -->
  <div class="flex items-center justify-between p-4 border-b border-border lg:hidden">
    <a href="/" class="font-bold text-3xl text-accent" style="font-family: var(--font-inter);">Odnikud</a>
    <button
      id="sidebar-toggle"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="sidebar-body"
      class="focus-outline p-2"
    >
      <IconMenuDeep id="sidebar-open-icon" />
      <IconX id="sidebar-close-icon" class="hidden" />
    </button>
  </div>

  <!-- Corpo della sidebar -->
  <div
    id="sidebar-body"
    class="hidden lg:flex lg:flex-col px-6 py-6"
  >
    <!-- Titolo (solo desktop, su mobile è nella barra superiore) -->
    <a href="/" class="hidden lg:block mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 66" width="100%" role="img" aria-label="Odnikud" style="overflow: visible;">
        <text
          x="100" y="52"
          font-family="var(--font-inter)"
          font-size="40"
          font-weight="700"
          letter-spacing="1"
          fill="#003153"
          text-anchor="middle"
        >Odnikud</text>
      </svg>
    </a>

    <!-- Immagine autore -->
    <div class="mb-6 hidden lg:block">
      <img
        src="/images/io.jpg"
        alt="Antonio Vigilante"
        class="w-full aspect-square mx-0 object-cover rounded-full mix-blend-multiply"
      />
    </div>

    <!-- Navigazione -->
    <nav class="mb-6 font-title">
      <ul class="space-y-0.5">
        <li>
          <a
            href="/info"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/info") },
            ]}
          >
            <IconInfo class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">Info</span>
          </a>
        </li>
        <li>
          <a
            href="/tags"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/tags") },
            ]}
          >
            <IconHash class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">Tag</span>
          </a>
        </li>
        <li>
          <a
            href="/about"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/about") },
            ]}
          >
            <IconUser class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">Ego</span>
          </a>
        </li>
        <li>
          <a
            href="/libri"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/libri") },
            ]}
          >
            <IconBook class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">I miei libri</span>
          </a>
        </li>
        {
          SITE.showArchives && (
            <li>
              <a
                href="/archives"
                class:list={[
                  "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
                  { "text-accent font-semibold nav-active": isActive("/archives") },
                ]}
              >
                <IconArchive class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
                <span class="nav-label">Archivi</span>
              </a>
            </li>
          )
        }
        <li>
          <a
            href="/grafo"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/grafo") },
            ]}
          >
            <IconGraph class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">Grafo</span>
          </a>
        </li>
        <li>
          <a
            href="/foto"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/foto") },
            ]}
          >
            <IconPhoto class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">Foto</span>
          </a>
        </li>
        <li>
          <a
            href="/progetti"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/progetti") },
            ]}
          >
            <IconFolder class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">Progetti</span>
          </a>
        </li>
        <li>
          <a
            href="/search"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/search") },
            ]}
          >
            <IconSearch class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">Cerca</span>
          </a>
        </li>
        <li>
          <a
            href="/contatta"
            class:list={[
              "nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors",
              { "text-accent font-semibold nav-active": isActive("/contatta") },
            ]}
          >
            <IconMail class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">Contatta</span>
          </a>
        </li>
        <li>
          <a
            href="/rss.xml"
            class="nav-link group flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors"
          >
            <IconRss class="size-4 shrink-0 fill-transparent stroke-current stroke-2 transition-transform group-hover:rotate-6" />
            <span class="nav-label">RSS</span>
          </a>
        </li>
      </ul>
    </nav>

    <!-- Cambio tema -->
    {
      SITE.lightAndDarkMode && (
        <div class="mb-6">
          <button
            id="theme-btn"
            class="group focus-outline flex items-center gap-2 py-2 px-2 rounded text-sm hover:text-accent transition-colors w-full text-left"
            title="Cambia tema"
            aria-label="auto"
            aria-live="polite"
          >
            <IconHalfMoon class="size-4 shrink-0 stroke-current transition-transform group-hover:rotate-6" />
            <span>Cambia tema</span>
          </button>
        </div>
      )
    }

    <!-- Post in evidenza -->
    {
      featuredPosts.length > 0 && (
        <div>
          <h2 class="text-xs font-semibold uppercase tracking-wider text-foreground/50 mb-3 px-2">
            In evidenza
          </h2>
          <ul class="space-y-1">
            {featuredPosts.map(post => (
              <li>
                <a
                  href={getPath(post.id, post.filePath)}
                  class="block py-1.5 px-2 text-sm leading-snug hover:text-accent transition-colors rounded"
                >
                  {post.data.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</aside>

<script>
  function initSidebarToggle() {
    const btn = document.getElementById("sidebar-toggle");
    const body = document.getElementById("sidebar-body");
    const openIcon = document.getElementById("sidebar-open-icon");
    const closeIcon = document.getElementById("sidebar-close-icon");

    if (!btn || !body) return;

    btn.addEventListener("click", () => {
      const isOpen = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", isOpen ? "false" : "true");
      body.classList.toggle("hidden", isOpen);
      openIcon?.classList.toggle("hidden", !isOpen);
      closeIcon?.classList.toggle("hidden", isOpen);
    });
  }

  initSidebarToggle();
  document.addEventListener("astro:after-swap", initSidebarToggle);
</script>
