---
import { slugifyStr } from "@/utils/slugify";
import type { CollectionEntry } from "astro:content";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";
import { renderInlineMarkdown } from "@/utils/markdownInline";

export interface Props extends CollectionEntry<"blog"> {
  variant?: "h2" | "h3";
}

const { variant = "h2", data, id, filePath } = Astro.props;
const { title, description, pubDatetime, modDatetime, timezone, heroImage } = data;

const headerProps = {
  style: { viewTransitionName: slugifyStr(title), fontFamily: "var(--font-inter)", lineHeight: "1.25" },
  class: "font-bold decoration-dashed hover:underline text-[25.2px] sm:text-[28px]",
};
---

<li class="my-6">
  <a
    href={getPath(id, filePath)}
    class="inline-block text-lg font-medium text-accent decoration-dashed underline-offset-4 focus-visible:no-underline focus-visible:underline-offset-0"
  >
    {
      variant === "h2" ? (
        <h2 {...headerProps}>{title}</h2>
      ) : (
        <h3 {...headerProps}>{title}</h3>
      )
    }
  </a>
  <Datetime {pubDatetime} {modDatetime} {timezone} />
  {heroImage && (
    <img src={heroImage} alt={title} class="w-full rounded mb-2" />
  )}
  <p class="post-excerpt" set:html={renderInlineMarkdown(description)}></p>
</li>
