---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import postFilter from "@/utils/postFilter";

const posts = await getCollection("blog");
const filtered = posts.filter(postFilter);

const tagMap = new Map<string, string>();
for (const post of filtered) {
  for (const tag of post.data.tags) {
    tagMap.set(slugifyStr(tag), tag);
  }
}

const graphNodes = [
  ...filtered.map(post => ({
    id: post.id,
    label: post.data.title,
    type: "post",
    url: getPath(post.id, post.filePath),
  })),
  ...Array.from(tagMap.entries()).map(([slug, name]) => ({
    id: `__tag__${slug}`,
    label: name,
    type: "tag",
    url: `/tags/${slug}`,
  })),
];

const graphLinks = filtered.flatMap(post =>
  post.data.tags.map(tag => ({
    source: post.id,
    target: `__tag__${slugifyStr(tag)}`,
  }))
);

const graphData = { nodes: graphNodes, links: graphLinks };
---

<Layout title="Grafo — Odnikud">
  <main id="main-content" class="flex flex-col" style="height: calc(100dvh - 2rem)">
    <div class="px-4 pt-10 pb-3 border-b border-border shrink-0">
      <h1 class="text-2xl font-semibold sm:text-3xl mb-0.5">Grafo dei post</h1>
      <p class="text-xs text-foreground/50">
        Nodi blu: post &middot; Nodi arancioni: tag &middot; Scorri/pizzica per zoomare &middot; Trascina per spostare &middot; Clicca per aprire
      </p>
    </div>
    <div id="graph-container" class="relative flex-1 min-h-0 overflow-hidden">
      <canvas id="graph-canvas" class="w-full h-full" style="cursor: grab; touch-action: none; user-select: none"></canvas>
      <div
        id="graph-tooltip"
        class="pointer-events-none absolute z-10 hidden rounded bg-background border border-border px-2 py-1 text-xs shadow-md max-w-xs whitespace-nowrap"
      ></div>
    </div>
  </main>
  <Footer />
</Layout>

<script type="application/json" id="graph-data" set:html={JSON.stringify(graphData)} />

<script>
  import * as d3 from "d3";

  interface GraphNode extends d3.SimulationNodeDatum {
    id: string;
    label: string;
    type: "post" | "tag";
    url: string;
  }

  interface GraphLink extends d3.SimulationLinkDatum<GraphNode> {
    source: string | GraphNode;
    target: string | GraphNode;
  }

  function init() {
    const dataEl = document.getElementById("graph-data");
    const canvas = document.getElementById("graph-canvas") as HTMLCanvasElement | null;
    const tooltip = document.getElementById("graph-tooltip") as HTMLDivElement | null;
    const container = document.getElementById("graph-container");

    if (!dataEl || !canvas || !tooltip || !container) return;

    const ctx = canvas.getContext("2d")!;
    const { nodes, links }: { nodes: GraphNode[]; links: GraphLink[] } = JSON.parse(
      dataEl.textContent!
    );

    // --- Transform state ---
    const T = { x: 0, y: 0, k: 1 };

    function screenToWorld(sx: number, sy: number) {
      return { x: (sx - T.x) / T.k, y: (sy - T.y) / T.k };
    }

    function getNodeAt(sx: number, sy: number): GraphNode | undefined {
      const { x: wx, y: wy } = screenToWorld(sx, sy);
      const threshold = 14 / T.k;
      return nodes.find(n => {
        const nx = n.x ?? 0;
        const ny = n.y ?? 0;
        return Math.hypot(nx - wx, ny - wy) <= threshold;
      });
    }

    function getColors() {
      const s = getComputedStyle(document.documentElement);
      const isDark = document.documentElement.getAttribute("data-theme") === "dark";
      return {
        post: s.getPropertyValue("--color-accent").trim() || (isDark ? "#818cf8" : "#4f46e5"),
        tag: "#f97316",
        link: isDark ? "rgba(255,255,255,0.10)" : "rgba(0,0,0,0.09)",
        text: s.getPropertyValue("--color-foreground").trim() || (isDark ? "#f1f5f9" : "#0f172a"),
      };
    }

    function draw() {
      const { width, height } = canvas;
      const c = getColors();

      ctx.clearRect(0, 0, width, height);
      ctx.save();
      ctx.translate(T.x, T.y);
      ctx.scale(T.k, T.k);

      // Links
      ctx.beginPath();
      ctx.strokeStyle = c.link;
      ctx.lineWidth = 1 / T.k;
      for (const link of links) {
        const s = link.source as GraphNode;
        const t = link.target as GraphNode;
        if (s.x == null || t.x == null) continue;
        ctx.moveTo(s.x, s.y!);
        ctx.lineTo(t.x, t.y!);
      }
      ctx.stroke();

      // Post nodes (below tags)
      ctx.fillStyle = c.post;
      for (const node of nodes) {
        if (node.type !== "post" || node.x == null) continue;
        ctx.beginPath();
        ctx.arc(node.x, node.y!, 4, 0, 2 * Math.PI);
        ctx.fill();
      }

      // Tag nodes + labels
      const showLabels = T.k > 0.6;
      for (const node of nodes) {
        if (node.type !== "tag" || node.x == null) continue;
        ctx.beginPath();
        ctx.arc(node.x, node.y!, 7, 0, 2 * Math.PI);
        ctx.fillStyle = c.tag;
        ctx.fill();

        if (showLabels) {
          const fontSize = Math.max(8, 11 / T.k);
          ctx.font = `${fontSize}px system-ui, sans-serif`;
          ctx.fillStyle = c.text;
          ctx.fillText(node.label, node.x + 10, node.y! + 4);
        }
      }

      ctx.restore();
    }

    // --- Simulation ---
    const simulation = d3
      .forceSimulation(nodes)
      .force(
        "link",
        d3
          .forceLink<GraphNode, GraphLink>(links)
          .id(d => d.id)
          .distance(55)
          .strength(0.6)
      )
      .force(
        "charge",
        d3.forceManyBody<GraphNode>().strength(d => (d.type === "tag" ? -250 : -60))
      )
      .force(
        "collision",
        d3.forceCollide<GraphNode>(d => (d.type === "tag" ? 22 : 7))
      )
      .force("x", d3.forceX().strength(0.04))
      .force("y", d3.forceY().strength(0.04))
      .alphaDecay(0.012)
      .on("tick", draw);

    let initialFitDone = false;

    function resize() {
      const rect = container.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
      simulation.force("center", d3.forceCenter(rect.width / 2, rect.height / 2));
      if (!initialFitDone) {
        initialFitDone = true;
        simulation.stop();
        for (let i = 0; i < 300; i++) simulation.tick();
        fitViewport();
        simulation.restart();
      }
      draw();
    }

    function fitViewport() {
      const xs = nodes.map(n => n.x ?? 0);
      const ys = nodes.map(n => n.y ?? 0);
      const minX = Math.min(...xs), maxX = Math.max(...xs);
      const minY = Math.min(...ys), maxY = Math.max(...ys);
      const padding = 40;
      T.k = Math.min(
        canvas.width / (maxX - minX + padding * 2),
        canvas.height / (maxY - minY + padding * 2),
        1
      ) * 1.0;
      const cx = (minX + maxX) / 2;
      const cy = (minY + maxY) / 2;
      T.x = canvas.width / 2 - cx * T.k;
      T.y = canvas.height / 2 - cy * T.k;
    }

    simulation.on("end", () => { fitViewport(); draw(); });

    // --- Interaction ---
    let dragNode: GraphNode | null = null;
    let isPanning = false;
    let panStart = { x: 0, y: 0 };
    let pointerDownPos = { x: 0, y: 0 };
    const activePointers = new Map<number, { x: number; y: number }>();
    let lastPinchDist = 0;
    let hadMultiTouch = false;

    function getPinchInfo() {
      const pts = Array.from(activePointers.values());
      return {
        dist: Math.hypot(pts[1].x - pts[0].x, pts[1].y - pts[0].y),
        mid: { x: (pts[0].x + pts[1].x) / 2, y: (pts[0].y + pts[1].y) / 2 },
      };
    }

    canvas.addEventListener("pointerdown", e => {
      activePointers.set(e.pointerId, { x: e.offsetX, y: e.offsetY });
      canvas.setPointerCapture(e.pointerId);

      if (activePointers.size >= 2) {
        hadMultiTouch = true;
        dragNode = null;
        isPanning = false;
        lastPinchDist = getPinchInfo().dist;
        return;
      }

      pointerDownPos = { x: e.offsetX, y: e.offsetY };
      const node = getNodeAt(e.offsetX, e.offsetY);
      if (node) {
        dragNode = node;
        simulation.alphaTarget(0.1).restart();
        dragNode.fx = dragNode.x;
        dragNode.fy = dragNode.y;
        canvas.style.cursor = "grabbing";
      } else {
        isPanning = true;
        panStart = { x: e.offsetX - T.x, y: e.offsetY - T.y };
        canvas.style.cursor = "grabbing";
      }
    });

    canvas.addEventListener("pointermove", e => {
      activePointers.set(e.pointerId, { x: e.offsetX, y: e.offsetY });

      if (activePointers.size >= 2) {
        const { dist, mid } = getPinchInfo();
        if (lastPinchDist > 0) {
          const factor = dist / lastPinchDist;
          T.x = mid.x - (mid.x - T.x) * factor;
          T.y = mid.y - (mid.y - T.y) * factor;
          T.k = Math.min(12, Math.max(0.05, T.k * factor));
          draw();
        }
        lastPinchDist = dist;
        return;
      }

      if (dragNode) {
        const w = screenToWorld(e.offsetX, e.offsetY);
        dragNode.fx = w.x;
        dragNode.fy = w.y;
      } else if (isPanning) {
        T.x = e.offsetX - panStart.x;
        T.y = e.offsetY - panStart.y;
        draw();
      } else {
        const node = getNodeAt(e.offsetX, e.offsetY);
        if (node) {
          tooltip.textContent = node.label;
          tooltip.classList.remove("hidden");
          tooltip.style.left = `${e.offsetX + 14}px`;
          tooltip.style.top = `${e.offsetY - 10}px`;
          canvas.style.cursor = "pointer";
        } else {
          tooltip.classList.add("hidden");
          canvas.style.cursor = "grab";
        }
      }
    });

    function cleanupPointer(e: PointerEvent) {
      activePointers.delete(e.pointerId);
      try { canvas.releasePointerCapture(e.pointerId); } catch {}

      if (activePointers.size === 1) {
        lastPinchDist = 0;
        const [rem] = activePointers.values();
        dragNode = null;
        isPanning = true;
        panStart = { x: rem.x - T.x, y: rem.y - T.y };
        return;
      }

      lastPinchDist = 0;
      const dx = e.offsetX - pointerDownPos.x;
      const dy = e.offsetY - pointerDownPos.y;
      const wasTap = Math.hypot(dx, dy) <= 8 && !hadMultiTouch;

      if (wasTap) {
        const node = getNodeAt(e.offsetX, e.offsetY);
        if (node) window.location.href = node.url;
      }

      if (dragNode) {
        simulation.alphaTarget(0);
        dragNode.fx = null;
        dragNode.fy = null;
        dragNode = null;
      }
      isPanning = false;
      hadMultiTouch = false;
      canvas.style.cursor = "grab";
    }

    canvas.addEventListener("pointerup", cleanupPointer);
    canvas.addEventListener("pointercancel", cleanupPointer);

    canvas.addEventListener(
      "wheel",
      e => {
        e.preventDefault();
        const factor = e.deltaY < 0 ? 1.12 : 1 / 1.12;
        T.x = e.offsetX - (e.offsetX - T.x) * factor;
        T.y = e.offsetY - (e.offsetY - T.y) * factor;
        T.k = Math.min(12, Math.max(0.05, T.k * factor));
        draw();
      },
      { passive: false }
    );

    new ResizeObserver(resize).observe(container);
    resize();
  }

  document.addEventListener("astro:page-load", init);
</script>
